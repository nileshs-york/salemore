{
    "version": 2,
    "functions": {
        "api/*.ts": {
            "includeFiles": "salemore.db"
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}